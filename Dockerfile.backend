# Flask backend — read/enqueue path only. The pipeline itself runs in the worker.
# Image used by AWS ECS Express Mode (Fargate + ALB) and locally via docker-compose.

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# System libs needed by pgvector/psycopg, markdown-pdf (Cairo), matplotlib, etc.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libpq5 \
        libcairo2 \
        libpango-1.0-0 \
        libpangocairo-1.0-0 \
        libgdk-pixbuf-2.0-0 \
        libffi-dev \
        curl \
        && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install deps first for layer caching.
COPY requirements.txt ./
RUN pip install -r requirements.txt

# Copy only what the backend needs at runtime (src/ is required because backend/app.py
# imports from utils.* and main; .dockerignore prunes the rest).
COPY backend/ ./backend/
COPY src/ ./src/

ENV HOST=0.0.0.0 \
    PORT=8000 \
    FLASK_ENV=production \
    ANALYZE_TIMEOUT_SECS=900

EXPOSE 8000

# Container-level healthcheck; the ALB target group also probes /api/health.
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -fsS http://localhost:${PORT}/api/health || exit 1

# Production server: gunicorn with a threaded worker. The single-threaded Flask
# dev server (`python -m backend.app`) serialized requests, so while the worker
# ran a pipeline the frontend's concurrent polls (3 horizons + price + history)
# queued behind one slow DB read and the ALB timed them out → 502. gthread
# workers handle the concurrent read/enqueue load so the load balancer always
# gets a prompt 200/202. Shell form so ${PORT}/overrides expand at runtime.
CMD gunicorn \
    --workers ${GUNICORN_WORKERS:-2} \
    --threads ${GUNICORN_THREADS:-8} \
    --worker-class gthread \
    --timeout ${GUNICORN_TIMEOUT:-120} \
    --bind 0.0.0.0:${PORT} \
    --access-logfile - \
    backend.app:app
