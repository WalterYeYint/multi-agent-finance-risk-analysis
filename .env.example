# .env.example
LANGCHAIN_API_KEY=YOUR_KEY_HERE
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT="Multi-Agent Finance Bot"

#---- Uncomment only one model below (For now) ----#
# OPENAI_API_KEY=YOUR_KEY_HERE
OLLAMA_MODEL="llama3.2:3b"

POLYGON_API_KEY=YOUR_KEY_HERE

#---- Postgres + pgvector RAG store ----#
# Single store for filing metadata + embeddings (replaces ChromaDB).
# Needs a Postgres with the pgvector extension available, e.g.:
#   docker run -e POSTGRES_USER=finance -e POSTGRES_PASSWORD=finance \
#     -e POSTGRES_DB=finance_rag -p 5432:5432 pgvector/pgvector:pg16
DATABASE_URL=postgresql://finance:finance@localhost:5432/finance_rag

#---- SEC EDGAR auto-ingest (src/utils/edgar_ingest.py) ----#
# SEC requires a real contact string or it throttles requests.
SEC_USER_AGENT="Your Name your-email@example.com"
FILINGS_RAW_DIR=./data/filings_raw